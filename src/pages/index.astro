---
const title = "Kurikomi";
const description =
  "An independent software company based in Uzbekistan. Maker of GitHub Store, RikkaUI, and RikkaIcons.";
const canonical = "https://kurikomi.com/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — open-source tools, made in Uzbekistan</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#F7F3ED" />
    <meta name="color-scheme" content="light" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://kurikomi.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://kurikomi.com/og.png" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preload" as="font" type="font/woff2" href="/fonts/fraunces-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-latin.woff2" crossorigin />

    <style is:global>
      @font-face {
        font-family: 'Fraunces';
        font-style: normal;
        font-weight: 300 500;
        font-display: swap;
        src: url('/fonts/fraunces-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Fraunces';
        font-style: normal;
        font-weight: 300 500;
        font-display: swap;
        src: url('/fonts/fraunces-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400 500;
        font-display: swap;
        src: url('/fonts/inter-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
      @font-face {
        font-family: 'Inter';
        font-style: normal;
        font-weight: 400 500;
        font-display: swap;
        src: url('/fonts/inter-latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
      }

      :root {
        --cream: #f7f3ed;
        --ink: #0e0e0e;
        --chestnut: #6b4423;
        --muted: #6b6b6b;
        --rule: rgba(14, 14, 14, 0.1);
        --serif: "Fraunces", Georgia, "Times New Roman", serif;
        --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui,
          sans-serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }

      body {
        margin: 0;
        background: var(--cream);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 1.0625rem;
        line-height: 1.7;
        font-feature-settings: "kern", "liga", "calt";
        font-variant-numeric: oldstyle-nums proportional-nums;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: inherit;
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.2em;
        text-decoration-color: var(--rule);
        transition: text-decoration-color 0.2s ease, color 0.2s ease;
      }
      a:hover {
        color: var(--chestnut);
        text-decoration-color: var(--chestnut);
      }
      a:focus-visible {
        outline: 2px solid var(--chestnut);
        outline-offset: 3px;
        border-radius: 2px;
      }

      ::selection {
        background: var(--ink);
        color: var(--cream);
      }

      .page {
        max-width: 38rem;
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
      }

      @media (min-width: 768px) {
        .page {
          padding: 6rem 2rem 8rem;
        }
      }

      header {
        margin-bottom: 6rem;
      }

      .brand {
        display: inline-flex;
        align-items: flex-end;
        gap: 0;
        margin-bottom: 5rem;
        text-decoration: none;
        color: var(--ink);
        line-height: 1;
        cursor: default;
      }

      .brand-mark {
        width: 20px;
        height: 30px;
        display: block;
        margin-bottom: -1px;
      }

      .brand-tail {
        font-family: var(--serif);
        font-weight: 500;
        font-variation-settings: "opsz" 24;
        font-size: 1.625rem;
        letter-spacing: -0.022em;
        line-height: 1;
        color: var(--ink);
        display: inline-flex;
        overflow: hidden;
        max-width: 0;
        margin-left: 0;
        transition:
          max-width 0.55s cubic-bezier(0.22, 0.61, 0.36, 1),
          margin-left 0.55s cubic-bezier(0.22, 0.61, 0.36, 1);
      }
      .brand-tail > span {
        display: inline-block;
        opacity: 0;
        transform: translateX(-5px);
        transition:
          opacity 0.28s ease,
          transform 0.28s ease;
      }
      .brand:hover .brand-tail,
      .brand:focus-visible .brand-tail {
        max-width: 8em;
        margin-left: 0.01em;
      }
      .brand:hover .brand-tail > span,
      .brand:focus-visible .brand-tail > span {
        opacity: 1;
        transform: none;
      }
      .brand:hover .brand-tail > span:nth-child(1),
      .brand:focus-visible .brand-tail > span:nth-child(1) { transition-delay: 0.04s; }
      .brand:hover .brand-tail > span:nth-child(2),
      .brand:focus-visible .brand-tail > span:nth-child(2) { transition-delay: 0.10s; }
      .brand:hover .brand-tail > span:nth-child(3),
      .brand:focus-visible .brand-tail > span:nth-child(3) { transition-delay: 0.16s; }
      .brand:hover .brand-tail > span:nth-child(4),
      .brand:focus-visible .brand-tail > span:nth-child(4) { transition-delay: 0.22s; }
      .brand:hover .brand-tail > span:nth-child(5),
      .brand:focus-visible .brand-tail > span:nth-child(5) { transition-delay: 0.28s; }
      .brand:hover .brand-tail > span:nth-child(6),
      .brand:focus-visible .brand-tail > span:nth-child(6) { transition-delay: 0.34s; }
      .brand:hover .brand-tail > span:nth-child(7),
      .brand:focus-visible .brand-tail > span:nth-child(7) { transition-delay: 0.40s; }
      @media (prefers-reduced-motion: reduce) {
        .brand-tail,
        .brand-tail > span {
          transition: none !important;
        }
      }

      h1 {
        font-family: var(--serif);
        font-weight: 400;
        font-variation-settings: "opsz" 96;
        font-size: clamp(1.875rem, 1.25rem + 2.8vw, 2.875rem);
        line-height: 1.13;
        letter-spacing: -0.018em;
        margin: 0 0 1.25rem;
        color: var(--ink);
        text-wrap: balance;
        font-feature-settings: "kern", "liga", "calt", "ss01";
      }

      .subhead {
        font-family: var(--sans);
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--muted);
        margin: 0;
        max-width: 32rem;
        text-wrap: balance;
      }

      section {
        margin-bottom: 5rem;
      }

      section:last-of-type {
        margin-bottom: 4rem;
      }

      .eyebrow {
        font-family: var(--sans);
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--muted);
        margin: 0 0 2rem;
      }

      p {
        margin: 0 0 1.4em;
        text-wrap: pretty;
      }

      p:last-child {
        margin-bottom: 0;
      }

      footer {
        border-top: 1px solid var(--rule);
        padding-top: 2rem;
        font-size: 0.9375rem;
        color: var(--muted);
        line-height: 1.75;
      }

      footer p {
        margin: 0;
      }

      footer a {
        color: var(--ink);
      }

      .globe {
        position: fixed;
        right: 2rem;
        bottom: 2rem;
        pointer-events: none;
        user-select: none;
        display: none;
        animation: globeFade 1.2s ease 0.7s both;
      }
      @media (min-width: 1100px) {
        .globe { display: block; }
      }
      @keyframes globeFade {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) {
        .globe { display: none; }
      }

      .reveal {
        opacity: 0;
        transform: translateY(8px);
        animation: reveal 0.7s cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
      }
      .r-1 { animation-delay: 0.05s; }
      .r-2 { animation-delay: 0.18s; }
      .r-3 { animation-delay: 0.28s; }
      .r-4 { animation-delay: 0.38s; }
      .r-5 { animation-delay: 0.48s; }
      .r-6 { animation-delay: 0.58s; }

      @keyframes reveal {
        to {
          opacity: 1;
          transform: none;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .reveal {
          opacity: 1;
          transform: none;
          animation: none;
        }
        * {
          transition: none !important;
        }
      }
    </style>
  </head>
  <body>
    <main class="page">
      <header>
        <a class="brand reveal r-1" href="/" aria-label="Kurikomi" tabindex="0">
          <img class="brand-mark" src="/logo.svg" width="20" height="30" alt="" aria-hidden="true" />
          <span class="brand-tail" aria-hidden="true"
            ><span>u</span><span>r</span><span>i</span><span>k</span><span>o</span><span>m</span><span>i</span></span>
        </a>

        <h1 class="reveal r-2">Kurikomi builds open-source software for developers and the people who use it.</h1>
        <p class="subhead reveal r-3">An independent software company based in Uzbekistan.</p>
      </header>

      <section aria-labelledby="what" class="reveal r-4">
        <p id="what" class="eyebrow">What we make</p>
        <p>Kurikomi makes three products today.</p>
        <p>
          <a href="https://github-store.org">GitHub Store</a> is a cross-platform app
          store for GitHub releases. It runs on Android, Windows, macOS, and Linux.
          It has 13,000+ stars on GitHub and active users in 166 countries.
        </p>
        <p>
          <a href="https://rikkaui.dev">RikkaUI</a> is a component library for Jetpack
          Compose and Compose Multiplatform, built on the shadcn philosophy of code
          you own. No external dependency, no breaking updates, no lock-in.
        </p>
        <p>
          <a href="https://rikkaicons.dev">RikkaIcons</a> is a multi-style icon library
          for Android and Kotlin Multiplatform — the first of its kind in the ecosystem.
        </p>
        <p>All three are open-source under Apache 2.0.</p>
      </section>

      <section aria-labelledby="approach" class="reveal r-5">
        <p id="approach" class="eyebrow">Our approach</p>
        <p>
          Everything Kurikomi ships is open-source under Apache 2.0. We work in
          public, ship frequently, and plan for the long term over the hype cycle.
        </p>
      </section>

      <section aria-labelledby="company" class="reveal r-6">
        <p id="company" class="eyebrow">The company</p>
        <p>
          Kurikomi, Inc. was founded in 2026 and is headquartered in Bukhara,
          Uzbekistan. We work openly and ship frequently.
        </p>
        <p>
          For partnerships, integrations, or press:
          <a href="mailto:hello@kurikomi.com">hello@kurikomi.com</a>.
        </p>
      </section>

      <footer class="reveal r-6">
        <p>Kurikomi, Inc. &middot; Founded 2026 &middot; Made in Uzbekistan</p>
        <p>
          <a href="https://github.com/kurikomi-labs">GitHub</a>
          &middot;
          <a href="mailto:hello@kurikomi.com">hello@kurikomi.com</a>
        </p>
        <p>&copy; 2026</p>
      </footer>
    </main>

    <canvas id="globe" class="globe" aria-hidden="true"></canvas>

    <script>
      (() => {
        const canvas = document.getElementById("globe");
        if (!canvas || !canvas.getContext) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        // Continent bounding boxes: [latMin, latMax, lngMin, lngMax]
        // Hand-tuned from real geography to render recognizable Earth at low res.
        const LAND = [
          // North America
          [30, 72, -130, -60], [15, 30, -118, -80], [8, 18, -90, -78],
          // South America
          [0, 12, -82, -60], [-15, 0, -82, -38],
          [-30, -15, -75, -42], [-55, -30, -75, -55],
          // Greenland + Iceland
          [60, 83, -55, -20], [63, 66, -24, -13],
          // Europe + UK + Scandinavia
          [36, 60, -10, 40], [50, 71, 4, 32], [50, 60, -10, 2],
          // Asia + India + SE Asia + Japan
          [25, 75, 40, 175], [5, 25, 65, 100],
          [-10, 25, 95, 125], [30, 46, 128, 146],
          // Indonesia + Philippines
          [-10, 8, 95, 142], [5, 20, 118, 127],
          // Africa
          [12, 37, -17, 35], [-5, 12, -18, 50],
          [-20, -5, 10, 42], [-35, -20, 12, 35],
          // Madagascar
          [-26, -12, 42, 51],
          // Australia + NZ
          [-40, -10, 112, 154], [-47, -34, 165, 180],
          // Antarctica
          [-90, -65, -180, 180],
        ];

        function isLand(lat, lng) {
          while (lng > 180) lng -= 360;
          while (lng < -180) lng += 360;
          for (let i = 0; i < LAND.length; i++) {
            const b = LAND[i];
            if (lat >= b[0] && lat <= b[1] && lng >= b[2] && lng <= b[3]) return true;
          }
          return false;
        }

        // Render config
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        const W = 40, H = 20;
        const R = 9;
        const X_SCALE = 1.82;
        const FONT_PX = 12;
        const COL_W = 7;
        const ROW_H = 11;
        canvas.width = (W * COL_W) * dpr;
        canvas.height = (H * ROW_H) * dpr;
        canvas.style.width = (W * COL_W) + "px";
        canvas.style.height = (H * ROW_H) + "px";

        const ctx = canvas.getContext("2d");
        ctx.scale(dpr, dpr);
        ctx.font = FONT_PX + 'px ui-monospace, SFMono-Regular, Menlo, "Cascadia Mono", Consolas, monospace';
        ctx.textBaseline = "top";

        const LAND_CHARS  = ".,:;+=*#$&@%";
        const OCEAN_CHARS = " ..";
        const LAND_COLOR  = "rgba(107, 68, 35, 0.88)";
        const OCEAN_COLOR = "rgba(107, 68, 35, 0.28)";

        // Light: upper-right, in front of sphere (toward viewer)
        const lx = 0.35, ly = 0.45, lz = 0.82;
        // Earth axial tilt, ~23.5°, rotation around viewer's X (pole tips toward viewer)
        const TILT = 0.4101;
        const cT = Math.cos(TILT), sT = Math.sin(TILT);
        const R2D = 180 / Math.PI;

        let angle = 0;
        let running = !document.hidden;
        let lastT = 0;
        const stepMs = 1000 / 24;

        document.addEventListener("visibilitychange", () => {
          running = !document.hidden;
          if (running) requestAnimationFrame(frame);
        });

        const N = W * H;
        const charBuf = new Uint8Array(N);
        const layerBuf = new Uint8Array(N); // 0 empty, 1 ocean, 2 land
        const zb = new Float32Array(N);

        function frame(t) {
          if (!running) return;
          if (t - lastT < stepMs) {
            requestAnimationFrame(frame);
            return;
          }
          lastT = t;

          const ca = Math.cos(angle), sa = Math.sin(angle);
          charBuf.fill(0);
          layerBuf.fill(0);
          for (let i = 0; i < N; i++) zb[i] = -1e9;

          // Sample density tuned for ~28k iter/frame, full pixel coverage at 40x20.
          for (let th = 0; th < Math.PI; th += 0.05) {
            const sTh = Math.sin(th), cTh = Math.cos(th);
            const lat = 90 - th * R2D;
            for (let ph = 0; ph < 6.2832; ph += 0.014) {
              const lng = ph * R2D - 180;
              const cPh = Math.cos(ph), sPh = Math.sin(ph);
              // Local sphere point (Earth-fixed frame)
              const xL = sTh * cPh;
              const yL = cTh;
              const zL = sTh * sPh;
              // Spin around local Y (polar axis)
              const xs = xL * ca + zL * sa;
              const ys = yL;
              const zs = -xL * sa + zL * ca;
              // Tilt: rotate around viewer's X axis
              const xv = xs;
              const yv = ys * cT - zs * sT;
              const zv = ys * sT + zs * cT;
              // Orthographic projection
              const sx = (W * 0.5 + xv * R * X_SCALE) | 0;
              const sy = (H * 0.5 - yv * R) | 0;
              if (sx < 0 || sx >= W || sy < 0 || sy >= H) continue;
              const idx = sy * W + sx;
              if (zv <= zb[idx]) continue;
              zb[idx] = zv;
              // Lighting: normal == viewer-frame position on unit sphere
              const dot = xv * lx + yv * ly + zv * lz;
              const lum = Math.max(0, dot) * 0.7 + 0.3;
              if (isLand(lat, lng)) {
                const ci = Math.min(LAND_CHARS.length - 1, Math.max(0, (lum * LAND_CHARS.length) | 0));
                charBuf[idx] = ci;
                layerBuf[idx] = 2;
              } else {
                const ci = Math.min(OCEAN_CHARS.length - 1, (lum * OCEAN_CHARS.length) | 0);
                charBuf[idx] = ci;
                layerBuf[idx] = 1;
              }
            }
          }

          ctx.clearRect(0, 0, W * COL_W, H * ROW_H);
          // Two passes: ocean first (faint), land on top (bold)
          for (let r = 0; r < H; r++) {
            let oceanRow = "", landRow = "";
            for (let c = 0; c < W; c++) {
              const idx = r * W + c;
              const layer = layerBuf[idx];
              if (layer === 2) {
                landRow += LAND_CHARS[charBuf[idx]];
                oceanRow += " ";
              } else if (layer === 1) {
                oceanRow += OCEAN_CHARS[charBuf[idx]];
                landRow += " ";
              } else {
                oceanRow += " ";
                landRow += " ";
              }
            }
            ctx.fillStyle = OCEAN_COLOR;
            ctx.fillText(oceanRow, 0, r * ROW_H);
            ctx.fillStyle = LAND_COLOR;
            ctx.fillText(landRow, 0, r * ROW_H);
          }

          // ~30s per full revolution at 24fps
          angle += 0.0087;
          if (angle > 6.2832) angle -= 6.2832;
          requestAnimationFrame(frame);
        }

        requestAnimationFrame(frame);
      })();
    </script>
  </body>
</html>
